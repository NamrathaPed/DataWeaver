# DataWeaver environment variables
# Copy this to .env and fill in your keys

# Required: Google Gemini API key (free tier available at aistudio.google.com)
GOOGLE_API_KEY=AIzaSyBdSHGvUMLFR_Wjeva5azydM2vEvVHpOvA

# Optional: Gemini model override
# Defaults to gemini-1.5-flash (fast, free tier)
# Other options: gemini-1.5-pro, gemini-2.0-flash
# AGENT_MODEL=gemini-1.5-flash
# LLM_MODEL=gemini-1.5-flash

# Optional: Supabase credentials
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your_supabase_anon_key

# Optional: allow specific frontend origins in prod
# FRONTEND_ORIGIN=https://your-app.vercel.app
